        <span>+51 993 793 849</span>
      </a>
    </div>
    <div class="space-y-2">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-muted/80">Sígueme</p>
      <a
        href="https://www.instagram.com/aldryck_medina/"
        target="_blank"
        rel="noreferrer"
        aria-label="Visitar Instagram de Aldryck Medina"
        class="inline-flex items-center gap-2 underline-offset-4 transition-all duration-200 hover:-translate-y-0.5 hover:text-accent hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
