---
const year = new Date().getFullYear();
---

<footer
  class="border-t border-line py-10 text-sm text-ink-muted"
  role="contentinfo"
>
  <div
    class="mx-auto grid max-w-6xl gap-6 px-4 sm:grid-cols-2 sm:items-start sm:px-6 lg:grid-cols-4 lg:px-8"
  >
    <div class="space-y-2">
      <p class="font-display text-xl tracking-[0.12em] text-ink">ALDRYCK</p>
      <p>© {year} Aldryck. Fotografía deportiva.</p>
    </div>
    <div class="space-y-2">
      <p class="text-xs uppercase tracking-[0.18em] text-ink-muted/80">Contacto</p>
      <a
        href="https://wa.me/51993793849"
        target="_blank"
        rel="noreferrer"
        aria-label="Abrir WhatsApp de Aldryck Medina"
        class="inline-flex items-center gap-2 underline-offset-4 transition-all duration-200 hover:-translate-y-0.5 hover:text-accent hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="h-4 w-4"
          aria-hidden="true"
