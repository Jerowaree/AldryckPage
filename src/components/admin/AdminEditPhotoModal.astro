<dialog
  id="edit-photo-modal"
  class="m-auto w-[min(92vw,640px)] rounded-2xl border border-line bg-surface p-0 text-ink shadow-2xl shadow-black/40 backdrop:bg-black/70"
  aria-label="Editar foto"
>
  <form id="edit-photo-form" class="space-y-4 p-5 sm:p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-accent">
          Editar foto
        </p>
        <h3 class="mt-1 font-display text-3xl tracking-wide text-ink">
          Actualizar datos
        </h3>
      </div>
      <button
        id="close-edit-modal"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-line text-ink-muted transition-colors hover:text-ink"
        aria-label="Cerrar modal de edición"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12"></path>
        </svg>
      </button>
    </div>

    <input id="edit-photo-id" name="id" type="hidden" />

    <label class="grid gap-2 text-sm">
      <span class="text-ink-muted">Título</span>
      <input
        id="edit-photo-title"
        name="title"
        type="text"
        required
        minlength="2"
        maxlength="120"
        class="min-h-11 rounded-lg border border-line bg-surface-elevated px-3 text-sm text-ink outline-none transition-colors focus:border-accent"
      />
    </label>

    <label class="grid gap-2 text-sm">
      <span class="text-ink-muted">Descripción</span>
      <textarea
        id="edit-photo-description"
        name="description"
        rows="4"
        maxlength="300"
        class="resize-none rounded-lg border border-line bg-surface-elevated px-3 py-2 text-sm text-ink outline-none transition-colors focus:border-accent"
      ></textarea>
    </label>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-2 text-sm">
        <span class="text-ink-muted">Categoría</span>
        <select
          id="edit-photo-category"
          name="categoryId"
          required
          class="min-h-11 rounded-lg border border-line bg-surface-elevated px-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        ></select>
      </label>
      <label class="inline-flex items-center gap-2 self-end pb-2 text-sm text-ink-muted">
        <input
          id="edit-photo-published"
          name="isPublished"
          type="checkbox"
          class="h-4 w-4 rounded border-line bg-surface text-accent focus:ring-accent"
        />
        Publicada
      </label>
    </div>

    <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:justify-end">
      <button
        id="cancel-edit-modal"
        type="button"
        class="inline-flex min-h-11 items-center justify-center rounded-lg border border-line bg-surface px-5 text-sm font-medium text-ink-muted transition-colors hover:text-ink"
      >
        Cancelar
      </button>
      <button
        id="save-edit-modal"
        type="submit"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-accent px-5 text-sm font-semibold text-surface transition-colors hover:bg-accent-hover"
      >
        Guardar cambios
      </button>
    </div>
    <p id="edit-photo-status" class="text-sm text-ink-muted"></p>
  </form>
</dialog>
