<section class="grid gap-8 lg:grid-cols-2 lg:gap-10">
  <article class="rounded-2xl border border-line bg-surface-elevated p-6 sm:p-8">
    <h2 class="font-display text-3xl tracking-wide text-ink">Nueva categoría</h2>
    <p class="mt-3 text-sm leading-relaxed text-ink-muted">
      Crea una categoría para organizar tus fotos (por ejemplo: fútbol,
      atletismo o retratos).
    </p>
    <form id="category-form" class="mt-7 space-y-5">
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">Nombre</span>
        <input
          type="text"
          name="name"
          required
          placeholder="Ej: Futbol"
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        />
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">
          Nombre corto (opcional)
        </span>
        <input
          type="text"
          name="slug"
          placeholder="Se completa solo si lo dejas vacío"
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        />
      </label>
      <button
        type="submit"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-accent px-6 text-sm font-semibold text-surface transition-colors hover:bg-accent-hover"
      >
        Crear categoría
      </button>
    </form>
  </article>

  <article class="rounded-2xl border border-line bg-surface-elevated p-6 sm:p-8">
    <h2 class="font-display text-3xl tracking-wide text-ink">Subir foto</h2>
    <p class="mt-3 text-sm leading-relaxed text-ink-muted">
      Completa los campos y elige tu imagen. Al final solo toca en
      <span class="text-ink">Subir foto</span>.
    </p>
    <form id="photo-form" class="mt-7 space-y-5">
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">Título</span>
        <input
          type="text"
          name="title"
          required
          placeholder="Ej: Final del torneo"
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        />
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">Categoría</span>
        <select
          id="category-select"
          name="categoryId"
          required
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        >
          <option value="">Cargando categorías...</option>
        </select>
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">
          Descripción (opcional)
        </span>
        <textarea
          name="description"
          rows="3"
          placeholder="Ej: Partido nocturno en estadio"
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        ></textarea>
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">
          Fecha (opcional)
        </span>
        <input
          type="datetime-local"
          name="shotAt"
          class="w-full rounded-lg border border-line bg-surface px-4 py-3 text-sm text-ink outline-none transition-colors focus:border-accent"
        />
      </label>
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-ink-muted">Imagen</span>
        <input
          type="file"
          name="file"
          accept="image/jpeg,image/png,image/webp,image/avif"
          required
          class="block w-full text-sm text-ink-muted file:mr-4 file:rounded-lg file:border-0 file:bg-accent file:px-4 file:py-2.5 file:font-semibold file:text-surface hover:file:bg-accent-hover"
        />
      </label>
      <label class="inline-flex items-center gap-2 text-sm text-ink-muted">
        <input
          type="checkbox"
          name="isPublished"
          value="true"
          class="h-4 w-4 rounded border-line bg-surface text-accent focus:ring-accent"
        />
        Mostrar esta foto en la galería
      </label>
      <button
        type="submit"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-accent lg:px-10 lg:mx-3 text-sm font-semibold text-surface transition-colors hover:bg-accent-hover"
      >
        Subir foto
      </button>
    </form>
  </article>
</section>
